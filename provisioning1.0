#!/usr/bin/env bash
set -Eeuo pipefail

EMAIL="skysat331@gmail.com"
SSHD_CONFIG="/etc/ssh/sshd_config"
UFW_DEFAULT="/etc/default/ufw"
UFW_BEFORE="/etc/ufw/before.rules"
LOG_FILE="/var/log/bootstrap-remnawave.log"

COLOR_RESET='\033[0m'
COLOR_BLUE='\033[1;34m'
COLOR_GREEN='\033[1;32m'
COLOR_YELLOW='\033[1;33m'
COLOR_RED='\033[1;31m'

SSH_PORT=""

step() {
  printf "\n${COLOR_BLUE}[*] %s${COLOR_RESET}\n" "$1"
}

ok() {
  printf "${COLOR_GREEN}[OK] %s${COLOR_RESET}\n" "$1"
}

warn() {
  printf "${COLOR_YELLOW}[WARN] %s${COLOR_RESET}\n" "$1"
}

die() {
  printf "${COLOR_RED}[ERR] %s${COLOR_RESET}\n" "$1" >&2
  exit 1
}

on_error() {
  local line="$1"
  local cmd="$2"
  printf "\n${COLOR_RED}[ERR] Сбой на строке %s${COLOR_RESET}\n" "$line" >&2
  printf "${COLOR_RED}[ERR] Команда: %s${COLOR_RESET}\n" "$cmd" >&2
  printf "${COLOR_RED}[ERR] Подробности смотри в логе: %s${COLOR_RESET}\n" "$LOG_FILE" >&2
}

trap 'on_error "${LINENO}" "${BASH_COMMAND}"' ERR

setup_logging() {
  touch "$LOG_FILE"
  chmod 600 "$LOG_FILE"
  exec > >(tee -a "$LOG_FILE") 2>&1
}

show_plan() {
  printf "\n${COLOR_BLUE}План настройки VPS:${COLOR_RESET}\n"
  printf "  • обновляет систему\n"
  printf "  • ставит базовые пакеты\n"
  printf "  • ставит Docker из официального репозитория\n"
  printf "  • опционально ставит Nginx + stream + certbot\n"
  printf "  • ставит iperf3\n"
  printf "  • выключает IPv6 в UFW\n"
  printf "  • спрашивает SSH-порт\n"
  printf "  • меняет sshd_config\n"
  printf "  • добавляет UFW-правила\n"
  printf "  • правит ICMP в /etc/ufw/before.rules\n"
  printf "  • включает UFW\n"
  printf "  • проверяет SSH\n"
  printf "  • обновляет ядро HWE и перезагружает VPS\n\n"
}

require_root() {
  [[ "${EUID}" -eq 0 ]] || die "Запусти скрипт через sudo."
}

backup_file() {
  local file="$1"
  [[ -f "$file" ]] || return 0
  cp -a "$file" "${file}.bak.$(date +%F-%H%M%S)"
  ok "Создан бэкап: ${file}.bak.$(date +%F-%H%M%S) (имя может немного отличаться по секундам)"
}

prompt_yes_no() {
  local prompt="$1"
  local answer
  while true; do
    read -r -p "$prompt [y/n]: " answer
    case "${answer,,}" in
      y|yes) return 0 ;;
      n|no) return 1 ;;
      *) echo "Введите y или n" ;;
    esac
  done
}

prompt_ssh_port() {
  local port
  while true; do
    read -r -p "Введите новый SSH порт: " port
    [[ "$port" =~ ^[0-9]+$ ]] || { warn "Порт должен быть числом"; continue; }
    (( port >= 1 && port <= 65535 )) || { warn "Порт должен быть в диапазоне 1-65535"; continue; }
    SSH_PORT="$port"
    ok "Выбран SSH порт: ${SSH_PORT}"
    return 0
  done
}

check_authorized_keys() {
  step "Проверяю наличие authorized_keys"
  local user_home auth_file found=0

  if [[ -n "${SUDO_USER:-}" && "${SUDO_USER}" != "root" ]]; then
    user_home="$(getent passwd "$SUDO_USER" | cut -d: -f6)"
    auth_file="${user_home}/.ssh/authorized_keys"
    if [[ -s "$auth_file" ]]; then
      ok "Найден authorized_keys у пользователя ${SUDO_USER}: ${auth_file}"
      found=1
    fi
  fi

  if [[ -s "/root/.ssh/authorized_keys" ]]; then
    ok "Найден authorized_keys у root: /root/.ssh/authorized_keys"
    found=1
  fi

  (( found == 1 )) || die "Не найден ни один непустой authorized_keys. Сначала добавь SSH-ключ на VPS."
}

apt_update_upgrade() {
  step "Обновляю систему"
  apt update
  DEBIAN_FRONTEND=noninteractive apt -y upgrade
  ok "Система обновлена"
}

install_base_utils() {
  step "Устанавливаю базовые пакеты"
  apt install -y vim nano curl htop unzip gnupg ufw lsb-release ca-certificates apt-transport-https software-properties-common
  ok "Базовые пакеты установлены"
}

install_docker_official() {
  step "Устанавливаю Docker из официального репозитория"
  apt remove -y docker.io docker-doc docker-compose docker-compose-v2 podman-docker containerd runc || true

  install -m 0755 -d /etc/apt/keyrings
  curl -fsSL https://download.docker.com/linux/ubuntu/gpg -o /etc/apt/keyrings/docker.asc
  chmod a+r /etc/apt/keyrings/docker.asc

  cat >/etc/apt/sources.list.d/docker.sources <<EOF
Types: deb
URIs: https://download.docker.com/linux/ubuntu
Suites: $(. /etc/os-release && echo "${UBUNTU_CODENAME:-$VERSION_CODENAME}")
Components: stable
Architectures: $(dpkg --print-architecture)
Signed-By: /etc/apt/keyrings/docker.asc
EOF

  apt update
  apt install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
  systemctl enable docker
  systemctl restart docker
  docker --version
  ok "Docker установлен"
}

install_nginx_optional() {
  if prompt_yes_no "Установить nginx + stream + certbot?"; then
    step "Устанавливаю nginx, stream и certbot"
    apt install -y nginx libnginx-mod-stream certbot python3-certbot-nginx
    certbot register --non-interactive --agree-tos --email "$EMAIL" || warn "Certbot register завершился с ошибкой, проверь вручную."
    systemctl enable nginx
    systemctl restart nginx
    ok "Nginx и certbot установлены"
  else
    step "Пропускаю установку nginx"
    ok "Nginx пропущен"
  fi
}

install_iperf3() {
  step "Устанавливаю iperf3"
  apt install -y iperf3
  ok "iperf3 установлен"
}

configure_ufw_ipv6() {
  step "Отключаю IPv6 в UFW"
  backup_file "$UFW_DEFAULT"
  sed -i 's/^IPV6=.*/IPV6=no/' "$UFW_DEFAULT"
  grep '^IPV6=' "$UFW_DEFAULT"
  ok "IPv6 в UFW отключен"
}

configure_ssh() {
  step "Настраиваю SSH"
  backup_file "$SSHD_CONFIG"

  if grep -qE '^[#[:space:]]*Port[[:space:]]+' "$SSHD_CONFIG"; then
    sed -i "s/^[#[:space:]]*Port[[:space:]].*/Port ${SSH_PORT}/" "$SSHD_CONFIG"
  else
    echo "Port ${SSH_PORT}" >> "$SSHD_CONFIG"
  fi

  if grep -qE '^[#[:space:]]*PasswordAuthentication[[:space:]]+' "$SSHD_CONFIG"; then
    sed -i 's/^[#[:space:]]*PasswordAuthentication[[:space:]].*/PasswordAuthentication no/' "$SSHD_CONFIG"
  else
    echo 'PasswordAuthentication no' >> "$SSHD_CONFIG"
  fi

  if grep -qE '^[#[:space:]]*PubkeyAuthentication[[:space:]]+' "$SSHD_CONFIG"; then
    sed -i 's/^[#[:space:]]*PubkeyAuthentication[[:space:]].*/PubkeyAuthentication yes/' "$SSHD_CONFIG"
  else
    echo 'PubkeyAuthentication yes' >> "$SSHD_CONFIG"
  fi

  if grep -qE '^[#[:space:]]*KbdInteractiveAuthentication[[:space:]]+' "$SSHD_CONFIG"; then
    sed -i 's/^[#[:space:]]*KbdInteractiveAuthentication[[:space:]].*/KbdInteractiveAuthentication no/' "$SSHD_CONFIG"
  else
    echo 'KbdInteractiveAuthentication no' >> "$SSHD_CONFIG"
  fi

  sshd -t

  systemctl daemon-reload || true
  systemctl reload ssh || true
  systemctl restart ssh || true
  systemctl restart ssh.socket || true

  ok "SSH настроен"
}

configure_ufw_rules() {
  step "Настраиваю правила UFW"

  ufw --force reset
  ufw default deny incoming
  ufw default allow outgoing
  ufw allow "${SSH_PORT}/tcp"
  ufw limit "${SSH_PORT}/tcp"

  if [[ "${SSH_PORT}" != "22" ]]; then
    ufw delete allow 22/tcp || true
    ufw delete limit 22/tcp || true
  fi

  ok "Правила UFW настроены"
}

configure_ufw_icmp() {
  step "Отключаю ICMP в /etc/ufw/before.rules"
  backup_file "$UFW_BEFORE"

  python3 - <<'PY'
from pathlib import Path

path = Path("/etc/ufw/before.rules")
text = path.read_text()

input_block = """# ok icmp codes for INPUT
-A ufw-before-input -p icmp --icmp-type destination-unreachable -j DROP
-A ufw-before-input -p icmp --icmp-type time-exceeded -j DROP
-A ufw-before-input -p icmp --icmp-type parameter-problem -j DROP
-A ufw-before-input -p icmp --icmp-type echo-request -j DROP
-A ufw-before-input -p icmp --icmp-type source-quench -j DROP

# ok icmp code for FORWARD
-A ufw-before-forward -p icmp --icmp-type destination-unreachable -j DROP
-A ufw-before-forward -p icmp --icmp-type time-exceeded -j DROP
-A ufw-before-forward -p icmp --icmp-type parameter-problem -j DROP
-A ufw-before-forward -p icmp --icmp-type echo-request -j DROP
"""

lines = text.splitlines()
out = []
i = 0
replaced = False

while i < len(lines):
    line = lines[i]
    if line.strip() == "# ok icmp codes for INPUT" and not replaced:
      out.extend(input_block.splitlines())
      replaced = True
      i += 1
      while i < len(lines):
          l = lines[i].strip()
          if (
              l.startswith("-A ufw-before-input -p icmp")
              or l.startswith("-A ufw-before-forward -p icmp")
              or l == "# ok icmp code for FORWARD"
              or l == ""
          ):
              i += 1
              continue
          break
      continue
    out.append(line)
    i += 1

if not replaced:
    out.append("")
    out.extend(input_block.splitlines())

path.write_text("\n".join(out) + "\n")
PY

  ok "ICMP правила обновлены"
}

enable_ufw() {
  step "Включаю UFW"
  ufw disable || true
  ufw --force enable
  ufw status verbose
  ok "UFW включен"
}

verify_ssh_port() {
  step "Проверяю SSH порт"

  if systemctl is-active --quiet ssh.socket; then
    ss -tlnp | grep -E "LISTEN.+:${SSH_PORT}\b" >/dev/null || warn "Порт может не отображаться сразу из-за socket activation, но будет применён при подключении."
  else
    ss -tlnp | grep -E "LISTEN.+:${SSH_PORT}\b" >/dev/null || die "SSH не слушает порт ${SSH_PORT}"
  fi

  ok "Порт SSH установлен: ${SSH_PORT}"
}

upgrade_kernel_and_reboot() {
  step "Обновляю ядро до linux-generic-hwe-24.04"
  apt update
  apt install -y linux-generic-hwe-24.04
  apt remove -y linux-image-generic || true
  apt autoremove -y --purge
  ok "Ядро обновлено"

  step "Сервер будет перезагружен через 5 секунд"
  sleep 5
  reboot
}

main() {
  require_root
  setup_logging
  show_plan
  check_authorized_keys
  prompt_ssh_port
  apt_update_upgrade
  install_base_utils
  install_docker_official
  install_nginx_optional
  install_iperf3
  configure_ufw_ipv6
  configure_ssh
  configure_ufw_rules
  configure_ufw_icmp
  enable_ufw
  verify_ssh_port
  upgrade_kernel_and_reboot
}

main "$@"
